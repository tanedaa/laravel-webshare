{
  "name": "tanedaa/laravel-webshare",
  "description": "A small package that integrates webshare.io proxies into Laravel",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Tanedaa\\LaravelWebShare\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Tanedaa\\LaravelWebShare\\Providers\\WebShareServiceProvider"
      ],
      "aliases": {
        "WebShare": "Tanedaa\\LaravelWebShare\\Facades\\WebShare"
      }
    }
  },
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/database": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "scripts": {
    "test": "phpunit"
  },
  "archive": {
    "exclude": [
      "/.github",
      "/tests",
      "/.phpunit.cache",
      "/phpunit.xml",
      "/.idea",
      "/.vscode"
    ]
  }
}
